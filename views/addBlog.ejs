<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@700&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="/css/global.css"/>
    <link rel="stylesheet" href="/css/addBlog.css"/>
    <title>Add New Blog</title>
  </head>
  <body>
    <%- include('./partials/nav') %>

    <div class="form-card">
      <h2>Write a New Blog</h2>
      <p class="subtitle">Share your thoughts with the world.</p>

      <% if (locals.error) { %>
      <div class="alert-error">⚠ <%= locals.error %></div>
      <% } %>

      <div class="ai-row">
        <div class="ai-label">✦ AI Content Generator</div>
        <label class="form-label" for="aiTopic">Enter a topic or idea</label>
        <input type="text" id="aiTopic" class="form-control"
          placeholder="e.g. Benefits of drinking water daily"/>
        <button class="btn-ai" onclick="generateContent()">
          ✦ Generate with AI
        </button>
      </div>

      <form action="/blog" method="post" enctype="multipart/form-data">
        <div class="mb-3">
          <label for="coverImage" class="form-label">Cover Image</label>
          <input type="file" class="form-control" id="coverImage" name="coverImage"/>
        </div>
        <div class="mb-3">
          <label for="title" class="form-label">Title</label>
          <input type="text" class="form-control" id="title" name="title"/>
        </div>
        <div class="mb-3">
          <label for="body" class="form-label">Body</label>
          <textarea name="body" class="form-control" id="body"></textarea>
        </div>
        <div class="mb-3">
          <button type="submit" class="btn-submit">Publish Blog</button>
        </div>
      </form>
    </div>

    <%- include('./partials/script') %>

    <script>
      window.addEventListener("pageshow", function (event) {
        if (event.persisted) {
          document.getElementById("aiTopic").value   = "";
          document.getElementById("title").value     = "";
          document.getElementById("body").value      = "";
          document.getElementById("coverImage").value = "";
        }
      });

      async function generateContent() {
        const topic = document.getElementById("aiTopic").value.trim();
        if (!topic) { alert("Please enter a topic first."); return; }

        const btn = document.querySelector(".btn-ai");
        btn.classList.add("loading");
        btn.textContent = "Generating...";

        try {
          const response = await fetch("/blog/generate-ai", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ topic }),
          });
          const data = await response.json();
          if (data.error) { alert("Error: " + data.error); return; }
          document.getElementById("title").value = data.title;
          document.getElementById("body").value  = data.body;
        } catch (error) {
          alert("AI generation failed. Please try again.");
          console.error(error);
        } finally {
          btn.classList.remove("loading");
          btn.innerHTML = " Generate with AI";
        }
      }
    </script>
  </body>
</html>