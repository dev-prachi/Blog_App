<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@700&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <link rel="stylesheet" href="/css/global.css"/>
    <link rel="stylesheet" href="/css/blog.css"/>
    <title><%= blog.title %></title>
  </head>
  <body>
    <%- include('./partials/nav') %>

    <div class="blog-article">
      <img class="cover" src="<%= blog.coverImageURL %>" alt="<%= blog.title %>" />
      <div class="blog-content">
        <h1><%= blog.title %></h1>

        <div class="author-row">
          <div class="author-info">
            <img src="<%= blog.createdBy.profileImageURL %>" alt="author" />
            <div>
              <div class="author-name">
                <i class="bi bi-person-circle" style="color:#6366f1;"></i>
                <%= blog.createdBy.fullName %>
              </div>
              <div class="author-date">
                <i class="bi bi-calendar3"></i>
                <%= new Date(blog.createdAt).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' }) %>
              </div>
            </div>
          </div>

          <!-- Like button -->
          <% if (locals.user) { %>
            <% const hasLiked = blog.likes.some(id => id.toString() === user._id.toString()); %>
            <form action="/blog/like/<%= blog._id %>" method="post" style="margin:0">
              <button type="submit" class="btn-like <%= hasLiked ? 'liked' : '' %>"
                style="background:<%= hasLiked ? '#fff0f0' : '#fff' %>; border:1.5px solid <%= hasLiked ? '#fecaca' : '#e5e7eb' %>; border-radius:8px; padding:0.45rem 1rem; font-size:0.9rem; font-weight:600; cursor:pointer; display:flex; align-items:center; gap:6px; color:<%= hasLiked ? '#ef4444' : '#6b7280' %>;">
                <i class="bi bi-heart<%= hasLiked ? '-fill' : '' %>"></i>
                <%= blog.likes.length %> <%= blog.likes.length === 1 ? 'Like' : 'Likes' %>
              </button>
            </form>
          <% } else { %>
            <span style="display:flex; align-items:center; gap:6px; color:#9ca3af; font-size:0.9rem; font-weight:600;">
              <i class="bi bi-heart"></i>
              <%= blog.likes.length %> <%= blog.likes.length === 1 ? 'Like' : 'Likes' %>
            </span>
          <% } %>

          <!-- Edit + Delete — creator only -->
          <% if (locals.user && blog.createdBy._id.toString() === user._id.toString()) { %>
          <div class="blog-actions">
            <a href="/blog/edit/<%= blog._id %>" class="btn-edit-blog">
              <i class="bi bi-pencil"></i> Edit
            </a>
            <form action="/blog/delete/<%= blog._id %>" method="post" style="margin:0">
              <button type="submit" class="btn-delete-blog"
                onclick="return confirm('Are you sure you want to delete this blog?')">
                <i class="bi bi-trash"></i> Delete
              </button>
            </form>
          </div>
          <% } %>
        </div>

        <div class="blog-body-text"><%= blog.body %></div>
      </div>
    </div>

    <div class="comments-section">
      <h2>
        <i class="bi bi-chat-dots" style="color:#6366f1;"></i>
        Comments (<%= comments.length %>)
      </h2>

      <% if (locals.user) { %>
      <form action="/blog/comment/<%= blog._id %>" method="post">
        <input type="text" name="content" class="comment-input" placeholder="Write a comment..."/>
        <button type="submit" class="btn-comment">
          <i class="bi bi-send"></i> Post Comment
        </button>
      </form>
      <% } else { %>
      <p style="color:#9ca3af; font-size:0.9rem;">
        <a href="/user/signin" style="color:#6366f1; font-weight:600;">Sign in</a>
        to leave a comment.
      </p>
      <% } %>

      <div class="mt-3">
        <% comments.forEach(comment => { %>
        <div class="comment-item">
          <img src="<%= comment.createdBy.profileImageURL %>" alt="commenter" />
          <div>
            <div class="comment-meta">
              <i class="bi bi-person" style="color:#6366f1;"></i>
              <%= comment.createdBy.fullName %>
            </div>
            <div class="comment-text"><%= comment.content %></div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>

    <%- include('./partials/script') %>
  </body>
</html>