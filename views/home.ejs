<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head') %>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
 
  <link rel="stylesheet" href="/css/global.css"/>
  <link rel="stylesheet" href="/css/home.css"/>
  <title>Homepage</title>
</head>
<body>
  <%- include('./partials/nav') %>

  <div class="container">
    <h1 class="page-heading">Latest Blogs</h1>
    <p class="page-subtext">Read, share, and explore ideas.</p>

    <!-- Search bar -->
    <form action="/" method="GET">
      <div class="search-wrap">
        <input
          type="text"
          name="search"
          value="<%= searchQuery %>"
          placeholder="Search blogs by title..."
          class="search-input"
        />
        <button type="submit" class="search-btn">
          <i class="bi bi-search"></i> Search
        </button>
        <% if (searchQuery) { %>
        <a href="/" class="search-clear-btn">
          <i class="bi bi-x"></i> Clear
        </a>
        <% } %>
      </div>
    </form>

    <!-- Search result count -->
    <% if (searchQuery) { %>
    <p style="color:#6b7280; font-size:0.9rem; margin-bottom:1rem;">
      Found <strong><%= blogs.length %></strong>
      result<%= blogs.length !== 1 ? 's' : '' %> for
      "<strong style="color:#6366f1;"><%= searchQuery %></strong>"
    </p>
    <% } %>

    
    <% if (locals.errorMessage) { %>
    <div class="alert-error">⚠ <%= locals.errorMessage %></div>
    <% } %>

    
    <% if (blogs.length === 0) { %>
    <div class="empty-state">
      <% if (searchQuery) { %>
        <p>No blogs found for "<strong><%= searchQuery %></strong>"</p>
        <a href="/" class="btn-view">Clear Search</a>
      <% } else { %>
        <p>No blogs yet. Be the first to write one!</p>
        <a href="/blog/add-new" class="btn-view">Write a Blog</a>
      <% } %>
    </div>

    <% } else { %>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
      <% blogs.forEach(blog => { %>
      <div class="col">
        <div class="blog-card">
          <img src="<%= blog.coverImageURL %>" alt="<%= blog.title %>" />
          <div class="blog-card-body">

            <h5 class="blog-card-title"><%= blog.title %></h5>

            <p class="blog-card-preview"><%= blog.body.substring(0, 100) %>...</p>

            <div class="card-actions">
              <a href="/blog/<%= blog._id %>" class="btn-view">View</a>

              
              <% if (locals.user) { %>
                <% const hasLiked = blog.likes.some(id => id.toString() === user._id.toString()); %>
                <form action="/blog/like/<%= blog._id %>" method="post" style="margin:0">
                  <button type="submit" class="btn-like <%= hasLiked ? 'liked' : '' %>">
                    <i class="bi bi-heart<%= hasLiked ? '-fill' : '' %>"></i>
                    <%= blog.likes.length %>
                  </button>
                </form>
              <% } else { %>
                <span class="btn-like">
                  <i class="bi bi-heart"></i>
                  <%= blog.likes.length %>
                </span>
              <% } %>

              
              <% if (locals.user && blog.createdBy && blog.createdBy._id.toString() === user._id.toString()) { %>
                <a href="/blog/edit/<%= blog._id %>" class="btn-edit">Edit</a>
                <form action="/blog/delete/<%= blog._id %>" method="post">
                  <button type="submit" class="btn-delete"
                    onclick="return confirm('Delete this blog?')">
                    Delete
                  </button>
                </form>
              <% } %>
            </div>

          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
  <div class="pagination-wrap">
    <a href="/?page=<%= currentPage - 1 %>&search=<%= searchQuery %>"
      class="page-btn nav-btn <%= currentPage === 1 ? 'disabled' : '' %>">
      <i class="bi bi-chevron-left"></i> Prev
    </a>
    <% for(let i = 1; i <= totalPages; i++) { %>
    <a href="/?page=<%= i %>&search=<%= searchQuery %>"
      class="page-btn <%= currentPage === i ? 'active' : '' %>">
      <%= i %>
    </a>
    <% } %>
    <a href="/?page=<%= currentPage + 1 %>&search=<%= searchQuery %>"
      class="page-btn nav-btn <%= currentPage === totalPages ? 'disabled' : '' %>">
      Next <i class="bi bi-chevron-right"></i>
    </a>
  </div>
  <p style="text-align:center; color:#9ca3af; font-size:0.85rem; margin-bottom:2rem;">
    Showing
    <strong><%= (currentPage - 1) * 6 + 1 %></strong> –
    <strong><%= Math.min(currentPage * 6, totalBlogs) %></strong>
    of <strong><%= totalBlogs %></strong> blogs
  </p>
  <% } %>

  <%- include('./partials/script') %>
</body>
</html>